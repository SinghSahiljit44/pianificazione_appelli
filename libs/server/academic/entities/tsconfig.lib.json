{
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "ignoreDeprecations": "5.0",
    "types": ["node", "jest"],
    "target": "es2021",
    "experimentalDecorators": true,
    // emitDecoratorMetadata intentionally omitted: this target is emitDeclarationOnly
    // (no JS output), so metadata emission is a no-op and only produces TS1272
    // false-positives on the Relation<> wrappers that break TypeORM circular deps.
    // Runtime metadata is emitted by the app build (tsconfig.app.json) and swc-jest.
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../../users/tsconfig.lib.json"
    }
  ]
}
